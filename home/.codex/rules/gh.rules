prefix_rule(
    pattern = ["gh", "pr", "list"],
    decision = "allow",
    justification = "Allow listing pull requests without prompting",
    match = [
        "gh pr list",
        "gh pr list --state open",
        "gh pr list --state closed",
        "gh pr list --author @me",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "view"],
    decision = "allow",
    justification = "Allow viewing pull request details without prompting",
    match = [
        "gh pr view",
        "gh pr view 123",
        "gh pr view --json number -q .number",
        "gh pr view --json title -q .title",
        "gh pr view --json body -q .body",
        "gh pr view --json mergeable -q .mergeable",
        "gh pr view --json number,title,body,mergeable",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "diff"],
    decision = "allow",
    justification = "Allow viewing pull request diffs without prompting",
    match = [
        "gh pr diff",
        "gh pr diff 123",
        "gh pr diff --patch",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "create"],
    decision = "allow",
    justification = "Allow creating pull requests without prompting",
    match = [
        "gh pr create",
        "gh pr create --title \"title\" --body \"body\"",
        "gh pr create --draft",
        "gh pr create --base main",
    ],
)

prefix_rule(
    pattern = ["gh", "pr", "edit"],
    decision = "allow",
    justification = "Allow editing pull requests without prompting",
    match = [
        "gh pr edit",
        "gh pr edit 123",
        "gh pr edit --title \"title\"",
        "gh pr edit --body \"body\"",
        "gh pr edit --add-label \"label\"",
        "gh pr edit --add-reviewer reviewer",
    ],
)
